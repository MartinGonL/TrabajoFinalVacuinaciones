@model Usuario

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0">Registrar Nuevo Usuario / Agente</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" enctype="multipart/form-data" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellido" class="form-label">Apellido</label>
                            <input asp-for="Apellido" class="form-control" required />
                            <span asp-validation-for="Apellido" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DNI" class="form-label">DNI</label>
                            <input asp-for="DNI" class="form-control" required />
                            <span asp-validation-for="DNI" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Matricula" class="form-label">Matrícula</label>
                            <input asp-for="Matricula" class="form-control" required />
                            <span asp-validation-for="Matricula" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo Electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="nombre@ejemplo.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Contraseña</label>
                            <input name="password" id="password" class="form-control" type="password" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Rol" class="form-label">Rol</label>
                        <select asp-for="Rol" class="form-select">
                            <option value="Agente" selected>Agente</option>
                            <option value="Administrador">Administrador</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="AvatarFile" class="form-label">Foto de Perfil (Avatar)</label>
                        <input asp-for="AvatarFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="AvatarFile" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4">Crear Usuario</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
