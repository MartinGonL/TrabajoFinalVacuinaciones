@model IEnumerable<Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios y Agentes";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">Gestión de Usuarios y Agentes</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            ➕ Crear Nuevo Usuario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Usuario</th>
                            <th>DNI</th>
                            <th>Matrícula</th>
                            <th>Email / Contacto</th>
                            <th>Rol</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.AvatarURL) ? "/uploads/avatars/default.png" : item.AvatarURL)" 
                                             alt="Avatar" 
                                             class="rounded-circle me-3 border" 
                                             style="width: 40px; height: 40px; object-fit: cover;" />
                                        <div>
                                            <h6 class="mb-0 fw-bold">@item.Nombre @item.Apellido</h6>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.DNI</td>
                                <td>@item.Matricula</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.Rol == "Administrador")
                                    {
                                        <span class="badge bg-danger">Administrador</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">Agente</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.UsuarioID" class="btn btn-sm btn-outline-info">Ver</a>
                                        <a asp-action="Edit" asp-route-id="@item.UsuarioID" class="btn btn-sm btn-outline-primary">Editar</a>
                                        <a asp-action="Delete" asp-route-id="@item.UsuarioID" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
