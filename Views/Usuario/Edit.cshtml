@model Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0">Editar Datos de Usuario</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" enctype="multipart/form-data" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="UsuarioID" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellido" class="form-label">Apellido</label>
                            <input asp-for="Apellido" class="form-control" required />
                            <span asp-validation-for="Apellido" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DNI" class="form-label">DNI</label>
                            <input asp-for="DNI" class="form-control" required />
                            <span asp-validation-for="DNI" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Matricula" class="form-label">Matrícula</label>
                            <input asp-for="Matricula" class="form-control" required />
                            <span asp-validation-for="Matricula" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo Electrónico</label>
                        <input asp-for="Email" class="form-control" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Nueva Contraseña (Dejar en blanco para mantener la actual)</label>
                        <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="Opcional" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Rol" class="form-label">Rol</label>
                            @if (User.IsInRole("Administrador"))
                            {
                                <select asp-for="Rol" class="form-select">
                                    <option value="Agente">Agente</option>
                                    <option value="Administrador">Administrador</option>
                                </select>
                            }
                            else
                            {
                                <input asp-for="Rol" class="form-control" readonly />
                            }
                            <span asp-validation-for="Rol" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                    </div>

                    <input type="hidden" asp-for="AvatarURL" />
                    
                    <div class="mb-4">
                        <label asp-for="AvatarFile" class="form-label d-block">Foto de Perfil (Avatar)</label>
                        <div class="d-flex align-items-center gap-3">
                            <img id="avatarPreview" src="@(string.IsNullOrEmpty(Model.AvatarURL) ? "/uploads/avatars/default.png" : Model.AvatarURL)" 
                                 alt="Avatar Preview" class="rounded-circle img-thumbnail shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" />
                            <div class="flex-grow-1">
                                <input asp-for="AvatarFile" id="avatarInput" type="file" class="form-control" accept="image/*" onchange="previewAvatar(this)" />
                                <span asp-validation-for="AvatarFile" class="text-danger"></span>
                                <small class="text-muted">Formatos aceptados: JPG, PNG, WEBP.</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4">Guardar Cambios</button>
                        
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        }
                        else
                        {
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
