@model Usuario

@{
    ViewData["Title"] = "Detalle del Usuario";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0">Información del Usuario</h4>
                <span class="badge bg-light text-primary fs-6">@Model.Rol</span>
            </div>
            <div class="card-body p-4">
                <div class="row align-items-center mb-4">
                    <div class="col-md-4 text-center">
                        <img src="@(string.IsNullOrEmpty(Model.AvatarURL) ? "/uploads/avatars/default.png" : Model.AvatarURL)" 
                             alt="Avatar" 
                             class="rounded-circle img-thumbnail shadow-sm mb-3" 
                             style="width: 150px; height: 150px; object-fit: cover;" />
                    </div>
                    <div class="col-md-8">
                        <h3 class="fw-bold mb-1">@Model.Nombre @Model.Apellido</h3>
                        <p class="text-muted mb-3"><i class="bi bi-envelope"></i> @Model.Email</p>
                        
                        <div class="row border-top pt-3">
                            <div class="col-6 mb-2">
                                <strong class="text-muted d-block" style="font-size: 0.85rem;">DNI</strong>
                                <span>@Model.DNI</span>
                            </div>
                            <div class="col-6 mb-2">
                                <strong class="text-muted d-block" style="font-size: 0.85rem;">Matrícula</strong>
                                <span>@Model.Matricula</span>
                            </div>
                            <div class="col-6 mb-2">
                                <strong class="text-muted d-block" style="font-size: 0.85rem;">Teléfono</strong>
                                <span>@(string.IsNullOrEmpty(Model.Telefono) ? "No especificado" : Model.Telefono)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Edit" asp-route-id="@Model.UsuarioID" class="btn btn-primary px-4">Editar Perfil</a>
                    
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver a la Lista</a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Volver al Inicio</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
