@{
    ViewData["Title"] = "Gestión de Alumnos";
}

<div id="app" class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold m-0">Gestión de Alumnos</h2>
            <p class="text-muted m-0">Administración de alumnos matriculados y sus escuelas asignadas.</p>
        </div>
        <div>
            <button class="btn btn-primary" @@click="abrirModalCrear">
                Nueva Ficha de Alumno
            </button>
        </div>
    </div>

    <div v-if="errorGeneral" class="alert alert-danger" role="alert">
        {{ errorGeneral }}
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    🔍
                </span>
                <input type="text" 
                       v-model="filtroNombre" 
                       class="form-control border-start-0" 
                       placeholder="Buscar por nombre o apellido..."
                       @@input="filtrarAlumnos">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nombre Completo</th>
                        <th>DNI</th>
                        <th>Fecha de Nacimiento</th>
                        <th>Teléfono Tutor</th>
                        <th>Escuela</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-if="cargando">
                        <td colspan="6" class="text-center py-5 text-muted">
                            Cargando datos de alumnos...
                        </td>
                    </tr>
                    <tr v-else-if="alumnosFiltrados.length === 0">
                        <td colspan="6" class="text-center py-5 text-muted">
                            No se encontraron alumnos registrados.
                        </td>
                    </tr>
                    <tr v-else v-for="alumno in alumnosFiltrados" :key="alumno.alumnoID">
                        <td class="ps-4">
                            <span class="fw-bold">{{ alumno.apellido }}, {{ alumno.nombre }}</span>
                        </td>
                        <td>{{ alumno.dni }}</td>
                        <td>{{ formatearFecha(alumno.fechaNacimiento) }}</td>
                        <td>{{ alumno.telefonoTutor || 'No asignado' }}</td>
                        <td>
                            <span class="badge bg-info text-dark">
                                {{ alumno.escuela ? alumno.escuela.nombre : 'Sin Escuela' }}
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm">
                                <a :href="'/RegistroVacunacion/Create?alumnoId=' + alumno.alumnoID" class="btn btn-outline-success">
                                    Vacunar
                                </a>
                                <button class="btn btn-outline-primary" @@click="abrirModalEditar(alumno)">
                                    Editar
                                </button>
                                <button v-if="esAdmin" class="btn btn-outline-danger" @@click="confirmarEliminar(alumno)">
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div v-if="totalPaginas > 1" class="card-footer bg-white d-flex justify-content-between align-items-center py-3 border-0">
            <div class="text-muted small">
                Página {{ paginaActual }} de {{ totalPaginas }}
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item" :class="{ disabled: paginaActual === 1 }">
                        <button class="page-link" @@click="cambiarPagina(paginaActual - 1)">Anterior</button>
                    </li>
                    <li v-for="p in totalPaginas" :key="p" class="page-item" :class="{ active: paginaActual === p }">
                        <button class="page-link" @@click="cambiarPagina(p)">{{ p }}</button>
                    </li>
                    <li class="page-item" :class="{ disabled: paginaActual === totalPaginas }">
                        <button class="page-link" @@click="cambiarPagina(paginaActual + 1)">Siguiente</button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <div class="modal fade" id="alumnoModal" tabindex="-1" aria-labelledby="alumnoModalLabel" aria-hidden="true" ref="modal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="alumnoModalLabel">{{ editando ? 'Editar Alumno' : 'Registrar Nuevo Alumno' }}</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" @@click="cerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div v-if="errorFormulario" class="alert alert-danger py-2 small">
                        {{ errorFormulario }}
                    </div>

                    <form @@submit.prevent="guardarAlumno">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Nombre *</label>
                                <input type="text" v-model="form.nombre" class="form-control form-control-sm" :class="{ 'is-invalid': errores.nombre }" placeholder="Nombre del alumno">
                                <div class="invalid-feedback small">{{ errores.nombre }}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Apellido *</label>
                                <input type="text" v-model="form.apellido" class="form-control form-control-sm" :class="{ 'is-invalid': errores.apellido }" placeholder="Apellido del alumno">
                                <div class="invalid-feedback small">{{ errores.apellido }}</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">DNI *</label>
                                <input type="text" v-model="form.dni" class="form-control form-control-sm" :class="{ 'is-invalid': errores.dni }" placeholder="Solo números">
                                <div class="invalid-feedback small">{{ errores.dni }}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Fecha de Nacimiento *</label>
                                <input type="date" v-model="form.fechaNacimiento" class="form-control form-control-sm" :class="{ 'is-invalid': errores.fechaNacimiento }">
                                <div class="invalid-feedback small">{{ errores.fechaNacimiento }}</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Teléfono del Tutor (Opcional)</label>
                            <input type="text" v-model="form.telefonoTutor" class="form-control form-control-sm" placeholder="Ej: 1123456789">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Escuela Asignada *</label>
                            <select v-model="form.escuelaID" class="form-select form-select-sm" :class="{ 'is-invalid': errores.escuelaID }">
                                <option :value="0" disabled>Seleccione una escuela...</option>
                                <option v-for="escuela in escuelas" :key="escuela.escuelaID" :value="escuela.escuelaID">
                                    {{ escuela.nombre }} (N° {{ escuela.numero || 'S/N' }})
                                </option>
                            </select>
                            <div class="invalid-feedback small">{{ errores.escuelaID }}</div>
                        </div>

                        <div class="text-end pt-3 border-top">
                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" data-bs-dismiss="modal" @@click="cerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-sm btn-primary">
                                {{ editando ? 'Guardar Cambios' : 'Registrar Alumno' }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script>
        const { createApp, ref, onMounted, computed } = Vue;

        createApp({
            setup() {
                const alumnos = ref([]);
                const escuelas = ref([]);
                const cargando = ref(false);
                const errorGeneral = ref('');
                const errorFormulario = ref('');
                const filtroNombre = ref('');

                const paginaActual = ref(1);
                const totalPaginas = ref(1);

                const editando = ref(false);
                const form = ref({
                    alumnoID: 0,
                    nombre: '',
                    apellido: '',
                    dni: '',
                    fechaNacimiento: '',
                    telefonoTutor: '',
                    escuelaID: 0
                });

                const errores = ref({
                    nombre: '',
                    apellido: '',
                    dni: '',
                    fechaNacimiento: '',
                    escuelaID: ''
                });

                let bootstrapModal = null;

                const esAdmin = ref(@(User.IsInRole("Administrador") ? "true" : "false"));

                const cargarAlumnos = async (pagina = 1) => {
                    cargando.value = true;
                    errorGeneral.value = '';
                    try {
                        const response = await fetch(`/api/alumnos?pagina=${pagina}`);
                        if (!response.ok) throw new Error('No se pudieron obtener los datos de los alumnos.');
                        
                        const data = await response.json();
                        alumnos.value = data.resultados || [];
                        paginaActual.value = data.paginaActual || 1;
                        totalPaginas.value = data.totalPaginas || 1;
                    } catch (err) {
                        errorGeneral.value = err.message;
                    } finally {
                        cargando.value = false;
                    }
                };

                const cargarEscuelas = async () => {
                    try {
                        const response = await fetch('/api/escuelas');
                        if (response.ok) {
                            escuelas.value = await response.json();
                        }
                    } catch (err) {
                        console.error('Error al cargar escuelas:', err);
                    }
                };

                const cambiarPagina = (p) => {
                    if (p >= 1 && p <= totalPaginas.value) {
                        cargarAlumnos(p);
                    }
                };

                const alumnosFiltrados = computed(() => {
                    if (!filtroNombre.value) return alumnos.value;
                    const filtro = filtroNombre.value.toLowerCase().trim();
                    return alumnos.value.filter(a => 
                        a.nombre.toLowerCase().includes(filtro) || 
                        a.apellido.toLowerCase().includes(filtro)
                    );
                });

                const formatearFecha = (fechaString) => {
                    if (!fechaString) return '';
                    const fecha = new Date(fechaString);
                    const dia = String(fecha.getDate()).padStart(2, '0');
                    const mes = String(fecha.getMonth() + 1).padStart(2, '0');
                    const anio = fecha.getFullYear();
                    return `${dia}/${mes}/${anio}`;
                };

                const formatearFechaParaInput = (fechaString) => {
                    if (!fechaString) return '';
                    return fechaString.split('T')[0];
                };

                const limpiarErrores = () => {
                    errores.value = {
                        nombre: '',
                        apellido: '',
                        dni: '',
                        fechaNacimiento: '',
                        escuelaID: ''
                    };
                    errorFormulario.value = '';
                };

                const inicializarFormulario = () => {
                    form.value = {
                        alumnoID: 0,
                        nombre: '',
                        apellido: '',
                        dni: '',
                        fechaNacimiento: '',
                        telefonoTutor: '',
                        escuelaID: 0
                    };
                    limpiarErrores();
                };

                const abrirModalCrear = () => {
                    inicializarFormulario();
                    editando.value = false;
                    if (!bootstrapModal) {
                        bootstrapModal = new bootstrap.Modal(document.getElementById('alumnoModal'));
                    }
                    bootstrapModal.show();
                };

                const abrirModalEditar = (alumno) => {
                    limpiarErrores();
                    editando.value = true;
                    form.value = {
                        alumnoID: alumno.alumnoID,
                        nombre: alumno.nombre,
                        apellido: alumno.apellido,
                        dni: alumno.dni,
                        fechaNacimiento: formatearFechaParaInput(alumno.fechaNacimiento),
                        telefonoTutor: alumno.telefonoTutor || '',
                        escuelaID: alumno.escuelaID
                    };
                    if (!bootstrapModal) {
                        bootstrapModal = new bootstrap.Modal(document.getElementById('alumnoModal'));
                    }
                    bootstrapModal.show();
                };

                const cerrarModal = () => {
                    if (bootstrapModal) {
                        bootstrapModal.hide();
                    }
                };

                const validarFormulario = () => {
                    let valido = true;
                    limpiarErrores();

                    if (!form.value.nombre.trim()) {
                        errores.value.nombre = 'El nombre es obligatorio.';
                        valido = false;
                    }
                    if (!form.value.apellido.trim()) {
                        errores.value.apellido = 'El apellido es obligatorio.';
                        valido = false;
                    }
                    if (!form.value.dni.trim()) {
                        errores.value.dni = 'El DNI es obligatorio.';
                        valido = false;
                    } else if (isNaN(form.value.dni.trim())) {
                        errores.value.dni = 'El DNI debe contener solo números.';
                        valido = false;
                    }
                    if (!form.value.fechaNacimiento) {
                        errores.value.fechaNacimiento = 'La fecha de nacimiento es obligatoria.';
                        valido = false;
                    }
                    if (form.value.escuelaID === 0) {
                        errores.value.escuelaID = 'Debe seleccionar una escuela.';
                        valido = false;
                    }

                    return valido;
                };

                const guardarAlumno = async () => {
                    if (!validarFormulario()) return;

                    const url = editando.value ? `/api/alumnos/${form.value.alumnoID}` : '/api/alumnos';
                    const metodo = editando.value ? 'PUT' : 'POST';

                    try {
                        const response = await fetch(url, {
                            method: metodo,
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(form.value)
                        });

                        if (!response.ok) {
                            const errorData = await response.json();
                            throw new Error(errorData.error || 'Ocurrió un error al procesar la solicitud.');
                        }

                        cerrarModal();
                        cargarAlumnos(paginaActual.value);
                    } catch (err) {
                        errorFormulario.value = err.message;
                    }
                };

                const confirmarEliminar = async (alumno) => {
                    const confirmacion = confirm(`¿Está seguro que desea eliminar al alumno ${alumno.nombre} ${alumno.apellido}?`);
                    if (confirmacion) {
                        try {
                            const response = await fetch(`/api/alumnos/${alumno.alumnoID}`, {
                                method: 'DELETE'
                            });
                            if (!response.ok) {
                                const errorData = await response.json();
                                throw new Error(errorData.error || 'No se pudo eliminar al alumno.');
                            }
                            cargarAlumnos(paginaActual.value);
                        } catch (err) {
                            errorGeneral.value = err.message;
                        }
                    }
                };

                onMounted(() => {
                    cargarAlumnos();
                    cargarEscuelas();
                });

                return {
                    alumnos,
                    escuelas,
                    cargando,
                    errorGeneral,
                    errorFormulario,
                    filtroNombre,
                    paginaActual,
                    totalPaginas,
                    editando,
                    form,
                    errores,
                    esAdmin,
                    alumnosFiltrados,
                    cambiarPagina,
                    formatearFecha,
                    abrirModalCrear,
                    abrirModalEditar,
                    cerrarModal,
                    guardarAlumno,
                    confirmarEliminar
                };
            }
        }).mount('#app');
    </script>
}
