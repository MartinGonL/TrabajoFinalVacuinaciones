@model IEnumerable<Vacuna>

@{
    ViewData["Title"] = "Gestión de Vacunas";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">Gestión de Vacunas</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            ➕ Registrar Nueva Vacuna
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 30%;">Nombre de la Vacuna</th>
                            <th style="width: 50%;">Descripción</th>
                            <th class="text-end pe-4" style="width: 20%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.NombreVacuna</td>
                                <td>@item.Descripcion</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.VacunaID" class="btn btn-sm btn-outline-info">Ver</a>
                                        <a asp-action="Edit" asp-route-id="@item.VacunaID" class="btn btn-sm btn-outline-primary">Editar</a>
                                        <a asp-action="Delete" asp-route-id="@item.VacunaID" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
