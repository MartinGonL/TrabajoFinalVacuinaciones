@model Vacuna

@{
    ViewData["Title"] = "Detalle de la Vacuna";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">Detalle de la Vacuna</h4>
            </div>
            <div class="card-body p-4">
                <div class="mb-3">
                    <h5 class="text-muted mb-1" style="font-size: 0.85rem; font-weight: bold; text-transform: uppercase;">Nombre de la Vacuna</h5>
                    <p class="fs-4 fw-bold text-primary">@Model.NombreVacuna</p>
                </div>
                <div class="mb-4">
                    <h5 class="text-muted mb-1" style="font-size: 0.85rem; font-weight: bold; text-transform: uppercase;">Descripción</h5>
                    <p class="text-secondary bg-light rounded p-3" style="min-height: 80px; white-space: pre-wrap;">@(string.IsNullOrEmpty(Model.Descripcion) ? "Sin descripción disponible." : Model.Descripcion)</p>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Edit" asp-route-id="@Model.VacunaID" class="btn btn-primary px-4">Editar</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver a la Lista</a>
                </div>
            </div>
        </div>
    </div>
</div>
