@model IEnumerable<Escuela>

@{
    ViewData["Title"] = "Gestión de Escuelas";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">Gestión de Escuelas</h2>
        @if (User.IsInRole("Administrador") || User.IsInRole("Agente"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                ➕ Registrar Nueva Escuela
            </a>
        }
    </div>

    <!-- Buscador de escuelas simple (estilo estudiante usando la API BuscarEscuelas o simple GET) -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="buscar" id="buscarInput" class="form-control" placeholder="Buscar escuela por nombre..." value="@Context.Request.Query["buscar"]" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">Buscar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaEscuelas">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 10%;">Foto</th>
                            <th style="width: 10%;">N°</th>
                            <th style="width: 40%;">Nombre de la Institución</th>
                            <th style="width: 25%;">Dirección</th>
                            <th class="text-end pe-4" style="width: 15%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var primeraFoto = item.Fotos?.FirstOrDefault()?.FotoURL;
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(primeraFoto))
                                    {
                                        <img src="@primeraFoto" alt="@item.Nombre" class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center border text-muted" style="width: 45px; height: 45px;">
                                            🏫
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold text-muted">@(item.Numero.HasValue ? item.Numero.Value.ToString() : "-")</td>
                                <td class="fw-bold text-primary">@item.Nombre</td>
                                <td>@item.Direccion</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.EscuelaID" class="btn btn-sm btn-outline-info">Ver</a>
                                        @if (User.IsInRole("Administrador") || User.IsInRole("Agente"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.EscuelaID" class="btn btn-sm btn-outline-primary">Editar</a>
                                        }
                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.EscuelaID" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
