@model IEnumerable<Escuela>

@{
    ViewData["Title"] = "Escuelas";
}

<h1>Escuelas</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Numero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Direccion)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Numero)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Direccion)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.EscuelaID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.EscuelaID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.EscuelaID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
