@model RegistroVacunacion

@{
    ViewData["Title"] = "Registrar Vacunación";
    var tieneAlumno = Model != null && Model.AlumnoID > 0;
    var alumno = ViewBag.Alumno as Alumno;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0">Registrar Aplicación de Vacuna</h4>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="AlumnoID" id="AlumnoID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small">Alumno *</label>
                        
                        <div id="searchWrapper" class="position-relative @(tieneAlumno ? "d-none" : "")">
                            <div class="input-group">
                                <span class="input-group-text bg-white">🔍</span>
                                <input type="text" id="alumnoSearch" class="form-control" placeholder="Buscar alumno por nombre, apellido o DNI..." autocomplete="off" />
                            </div>
                            <ul id="alumnoResults" class="list-group position-absolute w-100 shadow d-none" style="z-index: 1050; max-height: 200px; overflow-y: auto;">
                            </ul>
                        </div>

                        <div id="alumnoDetalle" class="card bg-light border-0 mt-2 @(tieneAlumno ? "" : "d-none")">
                            <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-bold mb-1 text-dark" id="detalleNombre">
                                        @(tieneAlumno ? $"{alumno?.Apellido}, {alumno?.Nombre}" : "")
                                    </h6>
                                    <p class="text-muted small mb-0">
                                        DNI: <span id="detalleDni">@(tieneAlumno ? alumno?.DNI : "")</span> | 
                                        Escuela: <span id="detalleEscuela">@(tieneAlumno ? (alumno?.Escuela?.Nombre ?? "Sin Escuela") : "")</span>
                                    </p>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger" id="btnQuitarAlumno">Cambiar</button>
                            </div>
                        </div>
                        <span asp-validation-for="AlumnoID" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FechaAplicacion" class="form-label fw-bold text-secondary small">Fecha de Aplicación *</label>
                            <input asp-for="FechaAplicacion" class="form-control" type="date" value="@Model?.FechaAplicacion.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="FechaAplicacion" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NumeroDosis" class="form-label fw-bold text-secondary small">Dosis N° *</label>
                            <input asp-for="NumeroDosis" class="form-control" type="number" min="1" required />
                            <span asp-validation-for="NumeroDosis" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="VacunaID" class="form-label fw-bold text-secondary small">Vacuna *</label>
                            <select asp-for="VacunaID" class="form-select" required>
                                <option value="">Seleccione la vacuna...</option>
                                @foreach (var vacuna in ViewBag.Vacunas)
                                {
                                    <option value="@vacuna.VacunaID">@vacuna.NombreVacuna</option>
                                }
                            </select>
                            <span asp-validation-for="VacunaID" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LugarVacunacion_EscuelaID" class="form-label fw-bold text-secondary small">Lugar / Escuela *</label>
                            <select asp-for="LugarVacunacion_EscuelaID" class="form-select" id="LugarVacunacion_EscuelaID" required>
                                <option value="">Seleccione el lugar...</option>
                                @foreach (var escuela in ViewBag.Escuelas)
                                {
                                    <option value="@escuela.EscuelaID">@escuela.Nombre @(escuela.Numero != null ? $"N° {escuela.Numero}" : "")</option>
                                }
                            </select>
                            <span asp-validation-for="LugarVacunacion_EscuelaID" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Observaciones" class="form-label fw-bold text-secondary small">Observaciones</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Ingresar observaciones o notas adicionales (opcional)"></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4">Guardar Registro</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputSearch = document.getElementById("alumnoSearch");
            const resultsList = document.getElementById("alumnoResults");
            const inputAlumnoId = document.getElementById("AlumnoID");
            const searchWrapper = document.getElementById("searchWrapper");
            const alumnoDetalle = document.getElementById("alumnoDetalle");
            const btnQuitar = document.getElementById("btnQuitarAlumno");

            const detalleNombre = document.getElementById("detalleNombre");
            const detalleDni = document.getElementById("detalleDni");
            const detalleEscuela = document.getElementById("detalleEscuela");
            const selectEscuela = document.getElementById("LugarVacunacion_EscuelaID");

            let debounceTimer;

            inputSearch.addEventListener("input", function () {
                clearTimeout(debounceTimer);
                const query = inputSearch.value.trim();

                if (query.length < 2) {
                    resultsList.classList.add("d-none");
                    resultsList.innerHTML = "";
                    return;
                }

                debounceTimer = setTimeout(() => {
                    fetch(`/api/alumnos?q=${encodeURIComponent(query)}`)
                        .then(response => {
                            if (!response.ok) throw new Error("Error en la búsqueda");
                            return response.json();
                        })
                        .then(data => {
                            resultsList.innerHTML = "";
                            if (data.length === 0) {
                                const li = document.createElement("li");
                                li.className = "list-group-item text-muted small";
                                li.textContent = "No se encontraron alumnos";
                                resultsList.appendChild(li);
                            } else {
                                data.forEach(alumno => {
                                    const li = document.createElement("li");
                                    li.className = "list-group-item list-group-item-action py-2";
                                    li.style.cursor = "pointer";
                                    li.innerHTML = `<strong>${alumno.apellido}, ${alumno.nombre}</strong> <span class="text-muted d-block small">DNI: ${alumno.dni} | Escuela: ${alumno.escuela ? alumno.escuela.nombre : 'Sin Escuela'}</span>`;
                                    
                                    li.addEventListener("click", function () {
                                        seleccionarAlumno(alumno);
                                    });
                                    resultsList.appendChild(li);
                                });
                            }
                            resultsList.classList.remove("d-none");
                        })
                        .catch(err => {
                            console.error(err);
                        });
                }, 300);
            });

            document.addEventListener("click", function (e) {
                if (e.target !== inputSearch && e.target !== resultsList) {
                    resultsList.classList.add("d-none");
                }
            });

            function seleccionarAlumno(alumno) {
                inputAlumnoId.value = alumno.alumnoID;
                detalleNombre.textContent = `${alumno.apellido}, ${alumno.nombre}`;
                detalleDni.textContent = alumno.dni;
                detalleEscuela.textContent = alumno.escuela ? alumno.escuela.nombre : "Sin Escuela";

                searchWrapper.classList.add("d-none");
                alumnoDetalle.classList.remove("d-none");

                if (alumno.escuelaID && selectEscuela) {
                    selectEscuela.value = alumno.escuelaID;
                }

                inputSearch.value = "";
                resultsList.innerHTML = "";
                resultsList.classList.add("d-none");
            }

            btnQuitar.addEventListener("click", function () {
                inputAlumnoId.value = "";
                detalleNombre.textContent = "";
                detalleDni.textContent = "";
                detalleEscuela.textContent = "";

                searchWrapper.classList.remove("d-none");
                alumnoDetalle.classList.add("d-none");
                inputSearch.focus();
            });
        });
    </script>
}
