@model Usuario

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center align-items-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0">Iniciar Sesión</h4>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form asp-controller="Auth" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo Electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="nombre@ejemplo.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" name="password" id="password" class="form-control" placeholder="Ingrese su contraseña" required />
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Ingresar</button>
                    </div>

                    <div class="text-center">
                        <p class="mb-0 text-muted">¿No tienes cuenta? <a asp-action="Register" class="text-primary font-weight-bold text-decoration-none">Registrarse</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
