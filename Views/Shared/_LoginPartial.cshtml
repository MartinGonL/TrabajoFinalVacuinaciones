@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <ul class="navbar-nav align-items-center">
        <li class="nav-item d-flex align-items-center me-3">
            <img src="@(User.FindFirst("AvatarURL")?.Value ?? "/uploads/avatars/default.png")" 
                 alt="Avatar" 
                 class="rounded-circle border" 
                 style="width: 32px; height: 32px; object-fit: cover; margin-right: 8px;" />
            <div class="d-flex flex-column text-start">
                <a class="nav-link text-dark py-0 fw-bold" asp-area="" asp-controller="Usuario" asp-action="Profile">
                    @User.Identity.Name
                </a>
                <small class="text-muted" style="font-size: 0.75rem; padding-left: 8px;">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </small>
            </div>
        </li>
        <li class="nav-item">
            <a class="btn btn-outline-danger btn-sm" asp-controller="Auth" asp-action="Logout">
                Cerrar Sesión
            </a>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="btn btn-outline-primary" asp-controller="Auth" asp-action="Login">
                Iniciar Sesión
            </a>
        </li>
    </ul>
}
